# ==================== OAKCRAFT CRM - ENVIRONMENT CONFIGURATION ====================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/oakcraft-crm
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/oakcraft-crm?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=24h

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
# To get app-specific password: https://myaccount.google.com/apppasswords

# Email Configuration (Alternative - Custom SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password

# Company Configuration
COMPANY_NAME=Oakcraft Furniture
COMPANY_EMAIL=crm@oakcraft.in
COMPANY_PHONE=+91-XXXXXXXXXX

# Password Generation
PASSWORD_PREFIX=Oak
PASSWORD_LENGTH=10

# Integration Keys
WHATSAPP_API_KEY=your-whatsapp-business-api-key
INDIAMART_API_KEY=your-indiamart-api-key
JUSTDIAL_API_KEY=your-justdial-api-key
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
GOOGLE_API_KEY=your-google-api-key

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email Templates
ENABLE_EMAIL_NOTIFICATIONS=true
EMAIL_TEMPLATE_PATH=./templates/emails

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
